APP_NAME=evolution-helpdesk-middleware
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8090

POSTGRES_USER=middleware_user
POSTGRES_PASSWORD=middleware_pass
POSTGRES_DB=middleware_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://middleware_user:middleware_pass@localhost:5432/middleware_db

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=evolution_exchange
RABBITMQ_QUEUE_IN=middleware.evolution.events
RABBITMQ_QUEUE_OUT=evolution.middleware.out
RABBITMQ_ROUTING_KEY_IN=#
RABBITMQ_ROUTING_KEY_OUT=helpdesk.out

EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_API_TIMEOUT=20

SUPPORT_WHATSAPP_NUMBER=
